{
  "groups": [
    {
      "name": "jwt",
      "type": "com.bootcamp.SpringEduManager.config.JwtProperties",
      "sourceType": "com.bootcamp.SpringEduManager.config.JwtProperties",
      "description": "Configuración de JWT"
    }
  ],
  "properties": [
    {
      "name": "jwt.secret",
      "type": "java.lang.String",
      "sourceType": "com.bootcamp.SpringEduManager.config.JwtProperties",
      "defaultValue": "SpringEduManagerSecretKey2026",
      "description": "Clave secreta para firmar los tokens JWT"
    },
    {
      "name": "jwt.expiration",
      "type": "java.lang.Long",
      "sourceType": "com.bootcamp.SpringEduManager.config.JwtProperties",
      "defaultValue": 86400000,
      "description": "Tiempo de expiración de los tokens JWT en milisegundos (default: 24 horas)"
    }
  ]
}
